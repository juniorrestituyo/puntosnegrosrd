# Supabase — públicas (van al cliente, OK exponer)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — privada (NUNCA al cliente, solo server)
SUPABASE_SERVICE_ROLE_KEY=

# Salt para hashear IPs (rate-limit). Genera string aleatorio largo (32+ caracteres).
IP_HASH_SALT=

# URL pública del sitio (para links permanentes en compartir-con-autoridad)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
